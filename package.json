{
  "name": "smart-autocorrect",
  "version": "1.0.1",
  "description": "On-device predictive text, autocorrect and link suggestions for Obsidian, powered by a local neural language model.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "vendor": "node vendor-engine.mjs",
    "typecheck": "tsgo -noEmit -skipLibCheck",
    "build": "pnpm typecheck && node esbuild.config.mjs production",
    "format": "prettier -l \"**/*.ts\"",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "mobile:check": "node esbuild.config.mjs production --bundle --platform=browser",
    "pre:push": "pnpm typecheck && pnpm format",
    "verify": "pnpm build && pnpm mobile:check"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "autocorrect",
    "predictive-text",
    "autocomplete",
    "offline",
    "language-model"
  ],
  "author": "Zangeti",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.38.6",
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260117.1",
    "chokidar": "5.0.0",
    "esbuild": "0.27.2",
    "obsidian": "1.11.4",
    "prettier": "3.8.0",
    "prettier-plugin-organize-imports": "4.3.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zangeti/obsidian-smart-autocorrect.git"
  }
}